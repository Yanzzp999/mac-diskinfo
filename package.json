{
  "name": "mac-diskinfo",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run build:electron && electron .\"",
    "prepare:smartctl-bundle": "node scripts/prepare-smartctl-bundle.mjs",
    "build": "npm run prepare:smartctl-bundle && tsc -b && vite build && npm run build:electron && node scripts/run-electron-builder.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:electron": "tsc -p electron/tsconfig.json && echo '{\"type\":\"commonjs\"}' > dist-electron/package.json",
    "verify:packaged": "node scripts/verify-packaged-app.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "plist": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yanzzp999/mac-diskinfo.git"
  },
  "main": "dist-electron/electron/main.js",
  "build": {
    "appId": "com.mac-diskinfo.app",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "public/icon.png",
      "target": [
        "dir",
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-resources/smartmontools",
        "to": "smartmontools"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Yanzzp999",
      "repo": "mac-diskinfo"
    }
  }
}
